<Window x:Class="PeakFinder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PeakFinder"
        mc:Ignorable="d"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="光谱去本底与拟合小工具" 
        Icon="/Frieren.ico"
        Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="2">
            <MenuItem Header="文件(_F)">
                <MenuItem Header="打开" Click="OpenFile_Click"/>
                <Separator />
                <MenuItem Header="保存" Click="Save_Click"/>
            </MenuItem>

            <MenuItem Header="帮助(_H)">
                <MenuItem Header="关于" Click="Help_Click"/>
            </MenuItem>
        </Menu>

        <StackPanel Grid.Row="1" Grid.Column="0" Margin="10,10,10,10">
            <CheckBox x:Name="ChkRemoveBaseline" Content="处理基线" IsChecked="True" Checked="Baseline_Toggle" Unchecked="Baseline_Toggle"/>
            <CheckBox x:Name="ChkEnableRange" Content="开启区间选择" Margin="0,10,0,0" Checked="Range_Toggle" Unchecked="Range_Toggle"/>
            <TextBlock Text="基线平滑度 (Log Lambda)" Margin="0,10,0,0"/>
            
            <DockPanel>
                <TextBox Width="45" DockPanel.Dock="Right" VerticalAlignment="Center"
                 Text="{Binding ElementName=SldLambda, Path=Value, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F1}}" 
                 KeyDown="TextBox_KeyDown"/>
                <Slider x:Name="SldLambda" Minimum="0.1" Maximum="10" Value="8" 
                TickFrequency="0.1" IsSnapToTickEnabled="True" 
                ValueChanged="Parameter_ValueChanged"/>
            </DockPanel>

            <TextBlock Text="不对称权重 (P)" Margin="0,10,0,0"/>
            <DockPanel>
                <TextBox Width="45" DockPanel.Dock="Right" VerticalAlignment="Center"
                 Text="{Binding ElementName=SldP, Path=Value, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F4}}"
                 KeyDown="TextBox_KeyDown"/>
                <Slider x:Name="SldP" Minimum="0.0001" Maximum="1" Value="0.05" 
                TickFrequency="0.0001" IsSnapToTickEnabled="True" 
                ValueChanged="Parameter_ValueChanged"/>
            </DockPanel>

            <Button Content="重置视图" Margin="0,20,0,0" Click="ResetView_Click"/>
            <ComboBox x:Name="ComboFitType" Margin="0,5,0,0" SelectedIndex="0">
                <ComboBoxItem Content="高斯峰 (Gaussian)"/>
                <ComboBoxItem Content="洛伦兹峰 (Lorentz)"/>
            </ComboBox>
            <Button Content="开始拟合 (基于标记点)" Margin="0,5,0,0" Click="Fit_Click" Background="#FF007ACC" Foreground="White" Height="30"/>
            <Button Content="清空所有标记" Margin="0,5,0,0" Click="ClearMarkers_Click"/>
            <Button Content="复制拟合结果" Margin="0,5,0,0" Click="CopyResults_Click" Background="#FF28A745" Foreground="White" Height="25"/>
            <ListBox x:Name="ResultList" Grid.Row="1" Grid.Column="0" Margin="5" Height="150" VerticalAlignment="Top"/>
            
        </StackPanel>



        <ScottPlot:WpfPlot Grid.Row="1" Grid.Column="1" x:Name="DataCanvas" Margin="5"/>

        <Grid Grid.Row="2" Grid.ColumnSpan="2" Background="#F3F3F3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="10,0">
                <Button Content="添加标记点" Click="AddMarker_Click" Margin="0,2"/>
            </StackPanel>

            <Grid Grid.Column="1" Margin="10,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="调整位置:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <Slider x:Name="MarkerSlider" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" IsEnabled="False" ValueChanged="MarkerSlider_ValueChanged"/>

                <TextBlock Text="范围选择:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                <Grid Grid.Row="1" Grid.Column="1">
                    <Slider x:Name="SliderStart" Margin="0,-5,0,0" Minimum="0" Maximum="100" Value="25" 
                            IsEnabled="{Binding ElementName=ChkEnableRange, Path=IsChecked}"
                            ValueChanged="RangeSlider_ValueChanged"/>
                    <Slider x:Name="SliderEnd" Margin="0,10,0,0" Minimum="0" Maximum="100" Value="75" Background="Transparent"
                            IsEnabled="{Binding ElementName=ChkEnableRange, Path=IsChecked}"
                            ValueChanged="RangeSlider_ValueChanged">
                        <Slider.Resources>
                            <Style TargetType="{x:Type RepeatButton}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                            </Style>
                        </Slider.Resources>
                    </Slider>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
